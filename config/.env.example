# ============= LLM 配置 =============
# 主 LLM（用于 Agent 推理）
LLM_PROVIDER=openai  # openai / anthropic / deepseek
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ID=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4000

# 备用 LLM（成本优化，可选）
# LLM_BACKUP_PROVIDER=deepseek
# LLM_BACKUP_API_KEY=your-backup-api-key
# LLM_BACKUP_BASE_URL=https://api.deepseek.com/v1
# LLM_BACKUP_MODEL_ID=deepseek-chat

# ============= 搜索 API =============
# Serper API（Web 搜索，可选）
# SERPER_API_KEY=your-serper-api-key
SERPER_ENABLED=false

# arXiv API（免费）
ARXIV_API_ENABLED=true
ARXIV_MAX_RESULTS=20

# ============= 工具配置 =============
# 代码执行
CODE_EXECUTOR_TIMEOUT=300
CODE_EXECUTOR_SANDBOX=true

# 可视化
FIGURE_DPI=300
FIGURE_FORMAT=png

# ============= 项目配置 =============
PROJECT_NAME=lightfars
MAX_ITERATIONS=3
LOG_LEVEL=INFO
LOG_FILE=logs/lightfars.log

# Git 配置
GIT_AUTO_COMMIT=true
GIT_COMMIT_MESSAGE_PREFIX="[LightFARS]"

# 状态管理
STATE_CHECK_INTERVAL=5  # 秒
